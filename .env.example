# Copy this file to .env and adjust if needed. NEVER commit your real .env.
#   cp .env.example .env
#
# This app runs against a LOCAL Ollama model over its OpenAI-compatible
# endpoint, so no real API key is required. Start Ollama and pull the model:
#   ollama pull llama3.2:3b
#
# These are the defaults the app already uses; override only if your setup
# differs.
OLLAMA_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
MODEL=llama3.2:3b
